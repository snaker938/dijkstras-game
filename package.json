{
  "name": "dijkstras-game",
  "version": "0.1.0",
  "main": "public/main.js",
  "private": true,
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "scripts": {
    "start": "vite --host 127.0.0.1 --port 3000",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "electron": "wait-on http://127.0.0.1:3000 && cross-env ELECTRON_IS_DEV=1 electron .",
    "electron:prod": "npm run build && cross-env ELECTRON_IS_DEV=0 electron .",
    "desktop": "npm run electron:prod",
    "dev": "concurrently -k \"npm:start\" \"npm:electron\""
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "vite": "^8.0.14",
    "wait-on": "^9.0.10"
  }
}
